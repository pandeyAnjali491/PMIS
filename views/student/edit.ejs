<%- layout('layouts/boilerplate/login.ejs') %>

<body class="body-bg body-text">
  <div class="container py-5 d-flex justify-content-center align-items-center">
    <div class="bg-white shadow-lg rounded-2xl p-4 w-100" style="max-width: 900px;">
      <h2 class="text-2xl font-bold text-center text-orange-500 mb-6">Edit Profile</h2>

      <form id="editForm" class="row g-3 needs-validation" action="/student/<%=student._id %>?_method=put" method="post" novalidate>
        <!-- Full Name -->
        <div class="col-md-6">
          <label class="form-label">Full Name</label>
          <input type="text" name="data[name]" value="<%= student.name %>" class="form-control" required>
        </div>

        <!-- Email -->
        <div class="col-md-6">
          <label class="form-label">Email</label>
          <input type="email" name="data[email]" value="<%= student.email %>" class="form-control" required>
        </div>

        <!-- Phone -->
        <div class="col-md-6">
          <label class="form-label">Phone</label>
          <input type="text" name="data[phone]" value="<%= student.phone %>" class="form-control" required>
        </div>

        <!-- DOB -->
        <div class="col-md-6">
          <label class="form-label">Date of Birth</label>
          <input type="date" name="data[dob]" value="<%= student.dob ? student.dob.toISOString().substring(0,10) : '' %>" class="form-control" required>
        </div>

        <!-- Gender -->
        <div class="col-md-6">
          <label class="form-label">Gender</label>
          <select name="data[gender]" class="form-select" required>
            <option value="">--Select Gender--</option>
            <option value="Male" <%= student.gender === "Male" ? "selected" : "" %>>Male</option>
            <option value="Female" <%= student.gender === "Female" ? "selected" : "" %>>Female</option>
            <option value="Other" <%= student.gender === "Other" ? "selected" : "" %>>Other</option>
          </select>
        </div>

        <!-- State -->
        <div class="col-md-6">
          <label class="form-label">State</label>
          <input type="text" name="data[state]" value="<%= student.state %>" class="form-control" required>
        </div>

        <!-- District -->
        <div class="col-md-6">
          <label class="form-label">District</label>
          <input type="text" name="data[district]" value="<%= student.district %>" class="form-control" required>
        </div>

        <!-- Education -->
        <div class="col-md-6">
          <label class="form-label">Education</label>
          <input type="text" name="data[education]" value="<%= student.education %>" class="form-control" required>
        </div>

        <!-- College -->
        <div class="col-md-6">
          <label class="form-label">College</label>
          <input type="text" name="data[college]" value="<%= student.college %>" class="form-control" required>
        </div>

        <!-- Year of Graduation -->
        <div class="col-md-3">
          <label class="form-label">Graduation Year</label>
          <input type="number" name="data[yearOfGraduation]" min="2000" max="2099" value="<%= student.yearOfGraduation %>" class="form-control" required>
        </div>

        <!-- Course -->
        <div class="col-md-3">
          <label class="form-label">Course</label>
          <input type="text" name="data[course]" value="<%= student.course %>" class="form-control" required>
        </div>

        <!-- Skills -->
        <div class="col-12">
          <label class="form-label">Skills (comma separated)</label>
          <textarea name="data[skills]" class="form-control"><%= student.skills %></textarea>
        </div>

        <!-- Preferred Domain -->
        <div class="col-md-6">
          <label class="form-label">Preferred Domain</label>
          <input type="text" name="data[preferred_domain]" value="<%= student.preferred_domain %>" class="form-control" required>
        </div>

        <!-- Internship Type -->
        <div class="col-md-6">
          <label class="form-label">Internship Type</label>
          <select name="data[internship_type]" class="form-select" required>
            <option value="">--Select Internship Type--</option>
            <option value="Remote" <%= student.internship_type === "Remote" ? "selected" : "" %>>Remote</option>
            <option value="Onsite" <%= student.internship_type === "Onsite" ? "selected" : "" %>>Onsite</option>
            <option value="Hybrid" <%= student.internship_type === "Hybrid" ? "selected" : "" %>>Hybrid</option>
          </select>
        </div>

        <!-- Password -->
        <div class="col-md-6">
          <label class="form-label">Password</label>
          <input type="password" id="password" name="data[password]" value="<%= student.password %>" class="form-control" required>
        </div>

        <!-- Confirm Password -->
        <div class="col-md-6">
          <label class="form-label">Confirm Password</label>
          <input type="password" id="confirm_password" value="<%= student.password %>" class="form-control" required>
          <p id="passwordError" class="text-danger small mt-1 hidden">Passwords do not match</p>
        </div>

        <!-- Submit -->
        <div class="col-12">
          <button class="btn btn-primary w-100" type="submit">Update Profile</button>
        </div>
      </form>
    </div>
  </div>
  <script>
    (() => {
      'use strict'
      const forms = document.querySelectorAll('.needs-validation')
      const password = document.getElementById('password')
      const confirmPassword = document.getElementById('confirm_password')
      const passwordError = document.getElementById('passwordError')

      Array.from(forms).forEach(form => {
        form.addEventListener('submit', event => {
          if (password.value !== confirmPassword.value) {
            confirmPassword.setCustomValidity("Passwords do not match")
            passwordError.classList.remove("hidden")
          } else {
            confirmPassword.setCustomValidity("")
            passwordError.classList.add("hidden")
          }
          if (!form.checkValidity()) {
            event.preventDefault()
            event.stopPropagation()
          }
          form.classList.add('was-validated')
        }, false)
      })
    })()
  </script>
</body>