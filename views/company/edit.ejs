<%- layout('layouts/boilerplate/company.ejs') %>

  <body class="body-bg body-text">
    <div class="container mx-auto px-4 py-12 flex justify-center items-center">
      <div class="bg-white shadow-lg rounded-2xl p-8 w-full max-w-3xl">
        <h2 class="text-2xl font-bold text-center text-orange-500 mb-6">
          Edit Company Profile
        </h2>

        <form id="companySignupForm" class="space-y-6 needs-validation" novalidate action="/company/<%= company._id %>?_method=PUT" method="post">
          <!-- Row 1 -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium mb-1 form-label">Company Name</label>
              <input type="text" name="data[name]" required class="w-full border rounded-lg p-2 form-control" value="<%= company.name %>"/>
              <div class="valid-feedback">Looks good!</div>
              <div class="invalid-feedback">Enter company name</div>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1 form-label">Email</label>
              <input type="email" name="data[email]" required class="w-full border rounded-lg p-2 form-control" value="<%= company.email %>"/>
              <div class="valid-feedback">Looks good!</div>
              <div class="invalid-feedback">Enter a valid email</div>
            </div>
          </div>

          <!-- Row 2 -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium mb-1 form-label">Phone</label>
              <input type="text" name="data[phone]" required class="w-full border rounded-lg p-2 form-control" value="<%= company.phone %>"/>
              <div class="valid-feedback">Looks good!</div>
              <div class="invalid-feedback">Enter a valid phone number</div>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1 form-label">Address</label>
              <input type="text" name="data[address]" required class="w-full border rounded-lg p-2 form-control" value="<%= company.address %>"/>
              <div class="valid-feedback">Looks good!</div>
              <div class="invalid-feedback">Enter a valid address</div>
            </div>
          </div>

          <!-- Row 3 -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium mb-1 form-label">State</label>
              <input type="text" name="data[state]" required class="w-full border rounded-lg p-2 form-control" value="<%= company.state %>"/>
              <div class="valid-feedback">Looks good!</div>
              <div class="invalid-feedback">Enter a valid state</div>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1 form-label">District</label>
              <input type="text" name="data[district]" required class="w-full border rounded-lg p-2 form-control" value="<%= company.district %>"/>
              <div class="valid-feedback">Looks good!</div>
              <div class="invalid-feedback">Enter a valid district</div>
            </div>
          </div>

          <!-- Row 4 -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium mb-1 form-label">Industry Type</label>
              <input type="text" name="data[industry_type]" placeholder="e.g. IT, Finance, Healthcare" required
                class="w-full border rounded-lg p-2 form-control" value="<%= company.industry_type %>"/>
              <div class="valid-feedback">Looks good!</div>
              <div class="invalid-feedback">Enter a valid industry type</div>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1 form-label">Job Type</label>
              <input type="text" name="data[job_type]" placeholder="e.g. Java Developer , Software Developer " required
                class="w-full border rounded-lg p-2 form-control" value="<%= company.job_type %>"/>
              <div class="valid-feedback">Looks good!</div>
              <div class="invalid-feedback">Enter a valid job type</div>
            </div>
          </div>
          <!-- row 5 -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium mb-1 form-label">Website</label>
              <input type="url" name="data[website]" placeholder="https://example.com"
                class="w-full border rounded-lg p-2 form-control" required value="<%= company.website %>"/>
              <div class="valid-feedback">Looks good!</div>
              <div class="invalid-feedback">Enter a valid website url</div>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1 form-label">HR Name</label>
              <input type="text" name="data[hr_name]" class="w-full border rounded-lg p-2 form-control" required value="<%= company.hr_name %>"/>
              <div class="valid-feedback">Looks good!</div>
              <div class="invalid-feedback">Enter a valid HR name</div>
            </div>
          </div>

          <!-- Row 5 (HR Info) -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium mb-1 form-label">HR Phone</label>
              <input type="text" name="data[hr_phone]" required class="w-full border rounded-lg p-2 form-control" value="<%= company.hr_phone %>"/>
              <div class="valid-feedback">Looks good!</div>
              <div class="invalid-feedback">Enter a valid HR phone number</div>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1 form-label">HR Email</label>
              <input type="email" name="data[hr_email]" required class="w-full border rounded-lg p-2 form-control" value="<%= company.hr_email %>"/>
              <div class="valid-feedback">Looks good!</div>
              <div class="invalid-feedback">Enter a valid HR email</div>
            </div>
          </div>

          <!-- Row 6 (Password + Confirm Password) -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium mb-1 form-label">Update Password</label>
              <input type="password" id="password" name="data[password]" required
                class="w-full border rounded-lg p-2 form-control" />
              <div class="valid-feedback">Looks good!</div>
              <div class="invalid-feedback">Enter a valid Password</div>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1 form-label">Confirm Password</label>
              <input type="password" id="confirm_password" required
                class="w-full border rounded-lg p-2 form-control" />
              <p id="passwordError" class="text-red-500 text-xs mt-1 hidden">Passwords do not match</p>
              <div class="valid-feedback">Looks good!</div>
              <div class="invalid-feedback">Enter a valid Password</div>
            </div>
          </div>

          <!-- Submit -->
          <button type="submit" class="w-full bg-orange-500 hover:bg-orange-600 text-white py-2 rounded-lg">
            Signup
          </button>
        </form>

        <p class="text-center text-sm mt-4">
          Already have an account?
          <a href="\company\login" class="text-blue-600">Login</a>
        </p>
      </div>
    </div>
    <script>
      (() => {
        'use strict'

        const forms = document.querySelectorAll('.needs-validation')
        const password = document.getElementById('password')
        const confirmPassword = document.getElementById('confirm_password')
        const passwordError = document.getElementById('passwordError')

        Array.from(forms).forEach(form => {
          form.addEventListener('submit', event => {
            if (password.value !== confirmPassword.value) {
              confirmPassword.setCustomValidity("Passwords do not match")
              passwordError.classList.remove("hidden")
            } else {
              confirmPassword.setCustomValidity("")
              passwordError.classList.add("hidden")
            }

            if (!form.checkValidity()) {
              event.preventDefault()
              event.stopPropagation()
            }

            form.classList.add('was-validated')
          }, false)
        })
      })()
      (() => {
  'use strict'

  // Fetch all forms with class 'needs-validation'
  const forms = document.querySelectorAll('.needs-validation')

  Array.from(forms).forEach(form => {
    form.addEventListener('submit', event => {
      if (!form.checkValidity()) {
        event.preventDefault()
        event.stopPropagation()
      }
      form.classList.add('was-validated')
    }, false)
  })
})()
    </script>

    </script>
  </body>