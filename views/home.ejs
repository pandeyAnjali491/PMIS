  <div class="chatbot-widget">
    <div class="chat-header">
      <h2>Internship Assistant</h2>
      <button class="close-btn">✖</button>
    </div>
    <div class="chat-messages">
      </div>
    <div class="chat-input">
      <textarea id="user-input" placeholder="Ask about internships..." required></textarea>
      <button id="reset-btn" title="Clear History">Clear</button>
      <button id="send-btn">Send</button>
    </div>
  </div>

<script>
    // --- Chatbot UI Elements ---
    const chatbotToggler = document.querySelector(".chatbot-toggler");
    const chatbotWidget = document.querySelector(".chatbot-widget");
    const closeBtn = document.querySelector(".close-btn");
    const chatMessages = document.querySelector(".chat-messages");
    const userInput = document.querySelector("#user-input");
    const sendBtn = document.querySelector("#send-btn");
    const resetBtn = document.querySelector("#reset-btn");

    // --- Initial Quick Reply Questions ---
    const initialQuestions = [
        "What is this scheme?",
        "Am I eligible?",
        "How do I apply?",
        "What documents are required?"
    ];

    // ✅ NEW questions and follow-ups added
    const relatedQuestions = {
        scheme: ["What are the benefits?", "How long is the internship?", "Am I eligible?"],
        benefits: ["What is the process?", "Will I get a certificate?", "How do I apply?"],
        stipend: ["What are the other benefits?", "How do I apply?"],
        duration: ["What is the selection process?", "Which companies participate?"],
        eligibility: ["What is the age limit?", "What qualifications do I need?", "Can final year students apply?"],
        age: ["What other eligibility criteria are there?", "How do I apply?"],
        education: ["Can final year students apply?", "What is the selection process?"],
        apply: ["What documents are required?", "When is the last date?", "What is the selection process?"],
        documents: ["How do I apply?", "What is the selection process?"],
        deadline: ["What is the selection process?", "What documents are required?"],
        selection: ["What happens after selection?", "Which companies participate?"],
        companies: ["Where are the internship locations?", "What is the stipend?", "How is selection done?"],
        location: ["Which companies participate?", "How do I apply?"],
        certificate: ["What are the other benefits?", "How long is the internship?"],
        help: ["How do I apply?", "What documents are required?", "Am I eligible?"],
        default: ["Am I eligible?", "How do I apply?", "What are the benefits?"]
    };

    const welcomeMessage = `
      <div class="chat-message bot-message">
        <p>Hello! 👋<br>I'm the PM Internship Scheme assistant. How can I help you today?</p>
      </div>`;

    // --- Function to show Quick Replies ---
    const showQuickReplies = (questions) => {
        const existingReplies = document.querySelector(".quick-replies");
        if (existingReplies) existingReplies.remove();

        const quickRepliesContainer = document.createElement("div");
        quickRepliesContainer.classList.add("quick-replies");
        questions.forEach(question => {
            const button = document.createElement("button");
            button.classList.add("quick-reply-btn");
            button.innerText = question;
            button.addEventListener("click", () => handleQuickReply(question));
            quickRepliesContainer.appendChild(button);
        });
        chatMessages.appendChild(quickRepliesContainer);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    };
    
    // --- Function to handle a quick reply click ---
    const handleQuickReply = (question) => {
        addMessage(question, "user");
        const repliesContainer = document.querySelector(".quick-replies");
        if (repliesContainer) repliesContainer.remove();
        setTimeout(() => getBotResponse(question), 800);
    }
    
    // --- Initialize the Chat ---
    const initializeChat = () => {
        chatMessages.innerHTML = "";
        chatMessages.insertAdjacentHTML("beforeend", welcomeMessage);
        showQuickReplies(initialQuestions);
    };

    // --- Toggle & Close Logic ---
    chatbotToggler.addEventListener("click", () => chatbotWidget.classList.toggle("open"));
    closeBtn.addEventListener("click", () => {
      chatbotWidget.classList.remove("open");
      setTimeout(initializeChat, 300);
    });

    // --- Function to add a message to the chat ---
    const addMessage = (message, sender) => {
      const messageElement = document.createElement("div");
      messageElement.classList.add("chat-message", sender + "-message");
messageElement.innerHTML = "<p>" + message + "</p>";
      chatMessages.appendChild(messageElement);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    };

    // --- Function to handle sending a typed message ---
    const handleSendMessage = () => {
      const message = userInput.value.trim();
      if (!message) return;
      const repliesContainer = document.querySelector(".quick-replies");
      if (repliesContainer) repliesContainer.remove();
      addMessage(message, "user");
      userInput.value = "";
      setTimeout(() => getBotResponse(message), 1000);
    };

    // --- 🤖 UPDATED BOT LOGIC with More Questions ---
    const getBotResponse = (userMessage) => {
        const msg = userMessage.toLowerCase();
        let reply = "I'm sorry, I don't have information on that. Please try another question.";
        let followUpKey = 'default';

        if (msg.includes("scheme") || msg.includes("what is this")) {
            reply = "The PM Internship Scheme is a government initiative to provide students with practical industry experience, mentorship, and skill development opportunities with leading organizations in India.";
            followUpKey = 'scheme';
        } else if (msg.includes("benefit") || msg.includes("advantage")) {
            reply = "Key benefits include 12 months of real-world project experience, a monthly stipend, mentorship from industry experts, and a certificate of completion from the Government of India.";
            followUpKey = 'benefits';
        } else if (msg.includes("stipend") || msg.includes("salary") || msg.includes("payment")) {
            reply = "Interns receive a monthly stipend to cover expenses. The exact amount consists of government and industry contributions. Please refer to the 'Core Benefits' section on the page for specific figures.";
            followUpKey = 'stipend';
        } else if (msg.includes("duration") || msg.includes("how long")) {
            reply = "The standard duration for internships under this scheme is 12 months, providing a comprehensive and immersive experience.";
            followUpKey = 'duration';
        } else if (msg.includes("eligible") || msg.includes("eligibility") || msg.includes("am i")) {
            reply = "General eligibility requires you to be an Indian citizen, aged 21-24, and not currently enrolled in full-time education or employment. For specific academic requirements, please check the official guidelines.";
            followUpKey = 'eligibility';
        } else if (msg.includes("age")) {
            reply = "The age limit for applicants is typically between 21 and 24 years. Please verify the exact age requirements on the official notification for the current year.";
            followUpKey = 'age';
        } else if (msg.includes("degree") || msg.includes("education") || msg.includes("qualification")) {
            reply = "While specific qualifications can vary by role, a bachelor's degree is usually the minimum requirement. Please click 'View Openings' to see the requirements for specific internship roles.";
            followUpKey = 'education';
        } else if (msg.includes("apply") || msg.includes("application") || msg.includes("register")) {
            reply = "To apply, you need to register on the official portal, fill out the application form with your details, upload the required documents, and submit it before the deadline. You can start by clicking the 'View Openings' button on this page.";
            followUpKey = 'apply';
        } else if (msg.includes("document") || msg.includes("what do i need")) {
            reply = "You will typically need your academic transcripts, a government-issued photo ID (like an Aadhaar card), a recent photograph, and your resume. Some roles may require a portfolio or statement of purpose.";
            followUpKey = 'documents';
        } else if (msg.includes("deadline") || msg.includes("last date")) {
            reply = "Application deadlines are announced for each cycle. Please refer to the official website or the 'Announcements' section for the most current dates.";
            followUpKey = 'deadline';
        } else if (msg.includes("selection") || msg.includes("how are candidates chosen")) {
            reply = "The selection process usually involves an initial screening of applications, followed by an aptitude test and/or an interview with the participating organizations.";
            followUpKey = 'selection';
        } 
        // ✅ NEW QUESTIONS START HERE
        else if (msg.includes("companies") || msg.includes("organizations")) {
            reply = "The scheme partners with a wide range of top companies, PSUs, and government bodies across various sectors like technology, finance, and marketing.";
            followUpKey = 'companies';
        } else if (msg.includes("location") || msg.includes("where")) {
            reply = "Internship locations are available across India. Both in-office and remote opportunities may be available, depending on the organization. You can filter by location when viewing openings.";
            followUpKey = 'location';
        } else if (msg.includes("certificate")) {
            reply = "Yes, upon successful completion of the 12-month internship, you will receive an official certificate from the Government of India, which is a valuable addition to your resume.";
            followUpKey = 'certificate';
        } else if (msg.includes("help") || msg.includes("contact") || msg.includes("support")) {
            reply = "For any technical issues or specific queries, please refer to the contact details provided on the official scheme portal. You can find a link in the website's footer.";
            followUpKey = 'help';
        } 
        // ✅ NEW QUESTIONS END HERE
        else if (msg.includes("thank")) {
            reply = "You're welcome! Is there anything else I can help you with?";
        }
        
        addMessage(reply, "bot");

        setTimeout(() => {
            showQuickReplies(relatedQuestions[followUpKey]);
        }, 1200);
    };

    // --- Event Listeners ---
    sendBtn.addEventListener("click", handleSendMessage);
    userInput.addEventListener("keydown", (event) => {
      if (event.key === "Enter" && !event.shiftKey) {
        event.preventDefault();
        handleSendMessage();
      }
    });
    resetBtn.addEventListener("click", () => {
        initializeChat();
    });
    
    // --- Start the chatbot ---
    initializeChat();
</script>


