<%- layout('/layouts/boilerplate/home.ejs') %>

<style>
  /* Chatbot Styling */
  .chatbot-toggler {
    position: fixed;
    bottom: 30px;
    right: 35px;
    width: 60px;
    height: 60px;
    background-color: var(--primary);
    color: white;
    border-radius: 50%;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    cursor: pointer;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    transition: all 0.2s ease;
    z-index: 999;
  }

  .chatbot-toggler:hover {
    transform: scale(1.1);
  }

  .chatbot-widget {
    position: fixed;
    bottom: 100px;
    right: 35px;
    width: 420px;
    background: white;
    border-radius: 15px;
    box-shadow: 0 0 128px 0 rgba(0, 0, 0, 0.1), 0 32px 64px -48px rgba(0, 0, 0, 0.5);
    transform: scale(0.5);
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s ease;
    z-index: 1000;
  }

  .chatbot-widget.open {
    transform: scale(1);
    opacity: 1;
    pointer-events: auto;
  }

  .chat-header {
    background: var(--primary);
    color: white;
    padding: 16px 20px;
    border-radius: 15px 15px 0 0;
    text-align: center;
    position: relative;
  }

  .chat-header h2 {
    font-size: 1.4rem;
    font-weight: bold;
  }

  .chat-header .close-btn {
    position: absolute;
    right: 15px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: white;
    font-size: 1.5rem;
    cursor: pointer;
  }

  .chat-messages {
    height: 350px;
    overflow-y: auto;
    padding: 20px;
  }

  .chat-message {
    margin-bottom: 15px;
    display: flex;
    align-items: flex-start;
    word-wrap: break-word;
  }

  .chat-message p {
    padding: 12px 16px;
    border-radius: 18px;
    font-size: 0.95rem;
    max-width: 75%;
  }

  .bot-message p {
    background-color: #f2f2f2;
    color: #333;
    border-bottom-left-radius: 0;
  }

  .user-message {
    justify-content: flex-end;
  }

  .user-message p {
    background-color: var(--primary);
    color: white;
    border-bottom-right-radius: 0;
  }

  .chat-input {
    display: flex;
    gap: 5px;
    padding: 15px 20px;
    border-top: 1px solid #ddd;
  }

  .chat-input textarea {
    flex-grow: 1;
    border: 1px solid #ccc;
    border-radius: 5px;
    padding: 10px;
    resize: none;
    height: 55px;
  }
  
  .chat-input button {
    background: var(--primary);
    color: white;
    border: none;
    padding: 0 20px;
    border-radius: 5px;
    cursor: pointer;
  }

  .quick-replies {
    padding: 0 20px 10px 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }

  .quick-reply-btn {
    background-color: #f1f1f1;
    border: 1px solid var(--primary);
    color: var(--primary);
    padding: 8px 15px;
    border-radius: 20px;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .quick-reply-btn:hover {
    background-color: var(--primary);
    color: white;
  }

  .chat-input button#reset-btn {
    background: #f1f1f1;
    color: #888;
    padding: 0 20px;
    font-size: 0.95rem;
    border: 1px solid #ccc;
  }

  .chat-input button#reset-btn:hover {
    background: #e0e0e0;
  }
</style>

